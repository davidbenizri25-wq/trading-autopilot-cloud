{
  "name": "Trading Autopilot",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && python3 -m unittest discover -s tests && python3 tools/validate_repo.py",
  "forwardPorts": [
    8501
  ],
  "portsAttributes": {
    "8501": {
      "label": "Trading Autopilot Dashboard",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  },
  "postStartCommand": "bash scripts/start_dashboard_background.sh"
}
